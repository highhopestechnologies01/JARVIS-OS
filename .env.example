# ============================================================
# JARVIS OS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=change_me_strong_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- Hermes (no prefix — mapped directly to Pydantic field names) ---
SECRET_KEY=change_me_32_char_secret_key_here
ENV=production
PORT=8000
LOG_LEVEL=INFO

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram (primary notification channel) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# --- Twilio (SMS / Voice Notifications) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
THOMAS_PHONE_NUMBER=+1...

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=your@email.com

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678

# --- Notion (optional) ---
NOTION_API_KEY=secret_...
NOTION_DASHBOARD_PAGE_ID=...

# --- Dashboard ---
NEXT_PUBLIC_HERMES_URL=http://hermes:8000
NEXT_PUBLIC_APP_NAME=JARVIS OS

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# --- Tailscale ---
# Your VPS Tailscale IP — find with: tailscale ip -4
VPS_TAILSCALE_IP=100.x.x.x
